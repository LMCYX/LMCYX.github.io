<!DOCTYPE html>
<html lang="zh">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>LYX · 小站</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Segoe UI', 'Roboto', system-ui, sans-serif;
    }

    body {
      background-color: #0a0e17;
      min-height: 100vh;
      overflow-x: hidden;
      color: #e0f0ff;
    }

    /* 固定导航栏 — 液态玻璃效果（无模糊，高折射/高光） */
    .navbar {
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      background: rgba(16, 28, 48, 0.15);
      backdrop-filter: none; /* 移除模糊 */
      -webkit-backdrop-filter: none;
      border-bottom: 1px solid rgba(80, 180, 255, 0.08);
      padding: 0.9rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      box-shadow: 
        0 8px 32px rgba(0, 0, 0, 0.3),
        inset 0 0 80px rgba(80, 180, 255, 0.02);
      border-radius: 0 0 24px 24px;
      margin: 0 12px;
      width: calc(100% - 24px);
      transition: 0.3s;
      /* 液态玻璃核心：高光、折射感 */
      background: radial-gradient(circle at 30% 20%, rgba(120, 200, 255, 0.08) 0%, rgba(10, 14, 23, 0.4) 80%);
      border: 1px solid rgba(255, 255, 255, 0.03);
      box-shadow: 
        0 8px 32px rgba(0, 0, 0, 0.5),
        inset 0 0 60px rgba(80, 180, 255, 0.03),
        inset 0 1px 0 rgba(255, 255, 255, 0.05);
    }

    .logo {
      font-size: 1.6rem;
      font-weight: 500;
      letter-spacing: 2px;
      background: linear-gradient(135deg, #a0d0ff, #3aa8ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-shadow: 0 0 30px rgba(58, 168, 255, 0.15);
    }

    .nav-links {
      display: flex;
      gap: 2.5rem;
      font-size: 1.1rem;
      font-weight: 400;
      position: relative;
    }

    .nav-links a {
      color: #b0d4ff;
      text-decoration: none;
      padding: 0.3rem 0.2rem;
      transition: 0.25s ease;
      letter-spacing: 1px;
      position: relative;
      cursor: pointer;
      text-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
    }

    .nav-links a:hover {
      color: #ffffff;
      text-shadow: 0 0 20px rgba(58, 168, 255, 0.4);
    }

    .nav-slider {
      position: absolute;
      bottom: -2px;
      height: 2px;
      background: linear-gradient(90deg, #5ab0ff, #a0d0ff);
      border-radius: 4px;
      box-shadow: 0 0 20px rgba(58, 168, 255, 0.5);
      transition: left 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94), width 0.35s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      will-change: left, width;
      pointer-events: none;
    }

    /* 主内容 */
    .content {
      position: relative;
      z-index: 10;
      max-width: 1200px;
      margin: 0 auto;
      padding: 7rem 2rem 4rem;
      min-height: 100vh;
      overflow: hidden;
    }

    .page-container {
      position: relative;
      width: 100%;
      overflow: hidden;
      min-height: 60vh;
    }

    .page {
      width: 100%;
      transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94), opacity 0.5s ease;
      will-change: transform, opacity;
      flex-shrink: 0;
      backface-visibility: hidden;
    }

    .page-home {
      transform: translateX(0);
      opacity: 1;
      position: relative;
    }

    .page-projects {
      transform: translateX(100%);
      opacity: 0;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
    }

    .page-container.show-projects .page-home {
      transform: translateX(-30%);
      opacity: 0;
      pointer-events: none;
      position: absolute;
      width: 100%;
    }

    .page-container.show-projects .page-projects {
      transform: translateX(0);
      opacity: 1;
      position: relative;
    }

    .page-container.slide-right .page-home {
      transform: translateX(0);
      opacity: 1;
      position: relative;
    }

    .page-container.slide-right .page-projects {
      transform: translateX(100%);
      opacity: 0;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
    }

    /* 项目卡片逐个滑出 (从右) */
    .project-card {
      opacity: 0;
      transform: translateX(40px);
      transition: opacity 0.4s ease, transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      transition-delay: 0s;
    }

    .page-container.show-projects .project-card {
      opacity: 1;
      transform: translateX(0);
    }

    .page-container.show-projects .project-card:nth-child(1) { transition-delay: 0.05s; }
    .page-container.show-projects .project-card:nth-child(2) { transition-delay: 0.10s; }
    .page-container.show-projects .project-card:nth-child(3) { transition-delay: 0.15s; }
    .page-container.show-projects .project-card:nth-child(4) { transition-delay: 0.20s; }
    .page-container.show-projects .project-card:nth-child(5) { transition-delay: 0.25s; }
    .page-container.show-projects .project-card:nth-child(6) { transition-delay: 0.30s; }
    .page-container.show-projects .project-card:nth-child(7) { transition-delay: 0.35s; }
    .page-container.show-projects .project-card:nth-child(8) { transition-delay: 0.40s; }

    /* ---- 首页 Hero (液态玻璃强化) ---- */
    .hero {
      background: radial-gradient(circle at 40% 30%, rgba(40, 120, 255, 0.06) 0%, rgba(8, 16, 30, 0.3) 80%);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-radius: 48px;
      padding: 3rem 4rem;
      border: 1px solid rgba(80, 180, 255, 0.06);
      box-shadow: 
        0 20px 60px rgba(0, 0, 0, 0.6),
        inset 0 0 80px rgba(80, 180, 255, 0.02),
        inset 0 1px 0 rgba(255, 255, 255, 0.04);
      margin-bottom: 0;
      transition: 0.3s;
      background: 
        radial-gradient(circle at 30% 20%, rgba(120, 220, 255, 0.15) 0%, transparent 60%),
        radial-gradient(circle at 70% 80%, rgba(60, 160, 255, 0.09) 0%, transparent 50%),
        radial-gradient(circle at 50% 50%, rgba(10, 14, 23, 0.6) 0%, rgba(10, 14, 23, 0.6) 100%);
      border: 1px solid rgba(255, 255, 255, 0.03);
    }

    .hero h1 {
      font-size: 3.8rem;
      font-weight: 300;
      letter-spacing: 4px;
      background: linear-gradient(to right, #c0e0ff, #6ab4ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: 0.5rem;
      text-shadow: 0 0 40px rgba(58, 168, 255, 0.1);
    }

    .hero h1 span {
      font-weight: 600;
      background: linear-gradient(135deg, #f0f9ff, #7fc6ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .hero p {
      font-size: 1.3rem;
      color: #b8d6f5;
      margin-top: 1rem;
      max-width: 600px;
      line-height: 1.6;
      border-left: 3px solid rgba(58, 168, 255, 0.3);
      padding-left: 1.5rem;
      text-shadow: 0 2px 20px rgba(0, 0, 0, 0.5);
    }

    .projects-section {
      margin-top: 0;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1.8rem;
    }

    .project-card {
      background: radial-gradient(circle at 30% 20%, rgba(80, 200, 255, 0.12) 0%, rgba(16, 28, 48, 0.6) 80%);
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-radius: 28px;
      padding: 1.8rem 1.5rem 1.8rem;
      border: 1px solid rgba(80, 180, 255, 0.12);
      box-shadow: 
        0 8px 32px rgba(0, 0, 0, 0.4),
        inset 0 0 60px rgba(80, 180, 255, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.09);
      transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
      display: flex;
      flex-direction: column;
      min-height: 220px;
      /* 变焦/折射感 */
      background: 
        radial-gradient(circle at 20% 30%, rgba(120, 220, 255, 0.04) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(60, 160, 255, 0.03) 0%, transparent 40%),
        radial-gradient(circle at 50% 50%, rgba(10, 14, 23, 0.3) 0%, rgba(10, 14, 23, 0.5) 100%);
      border: 1px solid rgba(255, 255, 255, 0.02);
    }

    .project-card:hover {
      transform: translateY(-6px) scale(1.01);
      border-color: rgba(100, 200, 255, 0.12);
      box-shadow: 
        0 16px 48px rgba(0, 40, 80, 0.5),
        inset 0 0 80px rgba(80, 180, 255, 0.04),
        inset 0 1px 0 rgba(255, 255, 255, 0.06);
      background: 
        radial-gradient(circle at 30% 20%, rgba(120, 220, 255, 0.08) 0%, transparent 60%),
        radial-gradient(circle at 70% 80%, rgba(60, 160, 255, 0.05) 0%, transparent 40%),
        radial-gradient(circle at 50% 50%, rgba(10, 14, 23, 0.2) 0%, rgba(10, 14, 23, 0.6) 100%);
    }

    .project-card h3 {
      font-size: 1.4rem;
      font-weight: 500;
      letter-spacing: 1px;
      color: #cce4ff;
      margin-bottom: 0.5rem;
      border-bottom: 1px solid rgba(80, 180, 255, 0.06);
      padding-bottom: 0.5rem;
      background: linear-gradient(135deg, #d0e8ff, #7fc0ff);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-shadow: 0 0 30px rgba(58, 168, 255, 0.05);
    }

    .project-card .desc {
      font-size: 0.95rem;
      color: #b0cef0;
      line-height: 1.5;
      margin: 0.5rem 0 1.2rem;
      flex: 1;
      opacity: 0.8;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
    }

    .project-card .btn {
      align-self: flex-start;
      background: rgba(40, 120, 255, 0.06);
      border: 1px solid rgba(80, 180, 255, 0.08);
      border-radius: 40px;
      padding: 0.5rem 1.6rem;
      font-size: 0.9rem;
      font-weight: 400;
      color: #b0d8ff;
      text-decoration: none;
      transition: 0.25s ease;
      letter-spacing: 1px;
      box-shadow: 0 2px 20px rgba(0, 0, 0, 0.2);
      cursor: pointer;
      display: inline-block;
      background: radial-gradient(circle at 50% 50%, rgba(80, 200, 255, 0.04) 0%, rgba(40, 120, 255, 0.02) 100%);
      border: 1px solid rgba(255, 255, 255, 0.03);
      text-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
    }

    .project-card .btn:hover {
      background: radial-gradient(circle at 50% 50%, rgba(80, 200, 255, 0.10) 0%, rgba(40, 120, 255, 0.06) 100%);
      border-color: rgba(80, 180, 255, 0.2);
      color: #ffffff;
      box-shadow: 0 0 30px rgba(58, 168, 255, 0.15);
      transform: scale(1.02);
    }

    .project-card .placeholder-icon {
      font-size: 1.8rem;
      margin-bottom: 0.3rem;
      opacity: 0.2;
      letter-spacing: 4px;
      color: rgba(80, 180, 255, 0.3);
      text-shadow: 0 0 20px rgba(58, 168, 255, 0.05);
    }

    /* 响应式 */
    @media (max-width: 1024px) {
      .projects-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }
    }

    @media (max-width: 700px) {
      .navbar {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.6rem;
        padding: 0.8rem 1.2rem;
        margin: 0 6px;
        width: calc(100% - 12px);
        border-radius: 0 0 16px 16px;
      }
      .nav-links {
        gap: 1.5rem;
        font-size: 1rem;
        flex-wrap: wrap;
      }
      .hero {
        padding: 2rem 1.5rem;
      }
      .hero h1 {
        font-size: 2.5rem;
      }
      .projects-grid {
        grid-template-columns: 1fr;
        gap: 1.2rem;
      }
    }

    /* 背景 canvas */
    #bg-canvas {
      position: fixed;
      top: 0;
      left: 0;
      width: 100vw;
      height: 100vh;
      z-index: 0;
      pointer-events: none;
      display: block;
    }
  </style>
</head>
<body>

  <nav class="navbar">
    <div class="logo">◈ LYX</div>
    <div class="nav-links" id="navLinks">
      <a data-page="home" class="active">首页</a>
      <a data-page="projects">项目</a>
      <span class="nav-slider" id="navSlider"></span>
    </div>
  </nav>

  <canvas id="bg-canvas"></canvas>

  <main class="content">
    <div class="page-container" id="pageContainer">
      <!-- 首页 -->
      <div class="page page-home" id="pageHome">
        <section class="hero">
          <h1><span>LYX</span> 的小站</h1>
          <p>
            电流在纳米间流动，
            逻辑于晶格中交织。
          </p>
        </section>
      </div>

      <!-- 项目页 -->
      <div class="page page-projects" id="pageProjects">
        <section class="projects-section">
          <div class="projects-grid" id="projectGrid">
            <!-- JS 生成 8 个卡片 -->
          </div>
        </section>
      </div>
    </div>
  </main>

  <script>
    (function() {
      // ========== 背景画布 ==========
      const canvas = document.getElementById('bg-canvas');
      const ctx = canvas.getContext('2d');
      let w = window.innerWidth, h = window.innerHeight;
      canvas.width = w; canvas.height = h;

      const SYMBOL_COUNT = 130;
      const BASE_SPEED = 0.25;
      const MAX_SPEED_VARY = 0.4;
      let symbols = [];
      const COLORS = [
        'rgba(80, 200, 255, 0.7)', 'rgba(50, 180, 255, 0.6)',
        'rgba(120, 220, 255, 0.5)', 'rgba(180, 130, 255, 0.5)',
        'rgba(60, 160, 255, 0.8)', 'rgba(30, 210, 230, 0.6)',
        'rgba(150, 200, 255, 0.5)'
      ];

      function drawTransistor(ctx, x, y, size, color, rotation = 0) {
        ctx.save(); ctx.translate(x, y); ctx.rotate(rotation);
        ctx.strokeStyle = color; ctx.lineWidth = 1.8;
        ctx.shadowColor = color; ctx.shadowBlur = 8;
        const s = size * 0.6;
        ctx.beginPath(); ctx.arc(0, 0, s * 0.5, 0, Math.PI * 2); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(-s * 0.8, -s * 0.5); ctx.lineTo(-s * 0.2, -s * 0.2); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(-s * 0.2, -s * 0.2); ctx.lineTo(-s * 0.4, 0); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(s * 0.2, s * 0.2); ctx.lineTo(s * 0.8, s * 0.5); ctx.stroke();
        ctx.beginPath(); ctx.arc(-s * 0.2, -s * 0.2, 3, 0, Math.PI * 2); ctx.fillStyle = color; ctx.fill();
        ctx.beginPath(); ctx.arc(s * 0.2, s * 0.2, 3, 0, Math.PI * 2); ctx.fill();
        ctx.restore();
      }
      function drawCircuitNode(ctx, x, y, size, color) {
        ctx.save(); ctx.translate(x, y);
        ctx.strokeStyle = color; ctx.lineWidth = 2;
        ctx.shadowColor = color; ctx.shadowBlur = 6;
        ctx.beginPath(); ctx.arc(0, 0, size * 0.35, 0, Math.PI * 2); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(-size * 0.5, -size * 0.5); ctx.lineTo(size * 0.5, size * 0.5);
        ctx.moveTo(size * 0.5, -size * 0.5); ctx.lineTo(-size * 0.5, size * 0.5); ctx.stroke();
        ctx.restore();
      }
      function drawCapacitor(ctx, x, y, size, color) {
        ctx.save(); ctx.translate(x, y);
        ctx.strokeStyle = color; ctx.lineWidth = 2.2;
        ctx.shadowColor = color; ctx.shadowBlur = 8;
        ctx.beginPath(); ctx.moveTo(-size * 0.25, -size * 0.6); ctx.lineTo(-size * 0.25, size * 0.6); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(size * 0.25, -size * 0.6); ctx.lineTo(size * 0.25, size * 0.6); ctx.stroke();
        ctx.beginPath(); ctx.moveTo(-size * 0.25, -size * 0.6); ctx.lineTo(-size * 0.6, -size * 0.6);
        ctx.moveTo(size * 0.25, size * 0.6); ctx.lineTo(size * 0.6, size * 0.6); ctx.stroke();
        ctx.restore();
      }

      function createSymbol() {
        const type = Math.floor(Math.random() * 3);
        const size = 12 + Math.random() * 22;
        const x = Math.random() * w, y = Math.random() * h;
        const color = COLORS[Math.floor(Math.random() * COLORS.length)];
        const speed = BASE_SPEED + Math.random() * MAX_SPEED_VARY;
        const rotation = Math.random() * Math.PI * 2;
        return { type, x, y, size, color, speed, rotation };
      }
      function initSymbols() { symbols = []; for (let i=0; i<SYMBOL_COUNT; i++) symbols.push(createSymbol()); }

      function drawScene() {
        ctx.clearRect(0, 0, w, h);
        ctx.save();
        for (let i = 0; i < symbols.length; i++) {
          const s1 = symbols[i];
          for (let j = 1; j <= 4; j++) {
            const idx = (i + j * 5) % symbols.length;
            const s2 = symbols[idx];
            if (!s1 || !s2) continue;
            const alpha = 0.12 + 0.08 * Math.sin(i + j);
            ctx.strokeStyle = `rgba(100, 200, 255, ${alpha})`;
            ctx.lineWidth = 0.7; ctx.shadowBlur = 0;
            ctx.beginPath(); ctx.moveTo(s1.x, s1.y); ctx.lineTo(s2.x, s2.y); ctx.stroke();
          }
          const extra = (i + 13) % symbols.length;
          const s3 = symbols[extra];
          if (s3 && i !== extra) {
            ctx.strokeStyle = `rgba(130, 210, 255, 0.06)`;
            ctx.lineWidth = 0.5;
            ctx.beginPath(); ctx.moveTo(s1.x, s1.y); ctx.lineTo(s3.x, s3.y); ctx.stroke();
          }
        }
        ctx.restore();
        for (let s of symbols) {
          const { type, x, y, size, color, rotation } = s;
          switch (type) {
            case 0: drawTransistor(ctx, x, y, size, color, rotation); break;
            case 1: drawCircuitNode(ctx, x, y, size, color); break;
            case 2: drawCapacitor(ctx, x, y, size, color); break;
          }
          ctx.beginPath(); ctx.arc(x, y, 2, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(200, 240, 255, 0.4)';
          ctx.shadowBlur = 12; ctx.shadowColor = '#8ac4ff'; ctx.fill();
        }
        ctx.save();
        ctx.strokeStyle = 'rgba(60, 160, 255, 0.03)'; ctx.lineWidth = 0.5;
        for (let i = 0; i < w; i += 40) { ctx.beginPath(); ctx.moveTo(i, 0); ctx.lineTo(i, h); ctx.stroke(); }
        for (let i = 0; i < h; i += 40) { ctx.beginPath(); ctx.moveTo(0, i); ctx.lineTo(w, i); ctx.stroke(); }
        ctx.restore();
      }

      function updatePositions() {
        for (let s of symbols) {
          s.y -= s.speed;
          if (s.y < -30) { s.y = h + 20 + Math.random() * 30; s.x = Math.random() * w;
            s.size = 12 + Math.random() * 26; s.type = Math.floor(Math.random() * 3);
            s.color = COLORS[Math.floor(Math.random() * COLORS.length)];
            s.speed = BASE_SPEED + Math.random() * MAX_SPEED_VARY; s.rotation = Math.random() * Math.PI * 2; }
        }
      }
      function animate() { updatePositions(); drawScene(); requestAnimationFrame(animate); }
      function handleResize() { w = window.innerWidth; h = window.innerHeight; canvas.width = w; canvas.height = h;
        for (let s of symbols) { s.x = Math.min(s.x, w-10); s.y = Math.min(s.y, h-10); if (s.x<0) s.x=Math.random()*w; if (s.y<0) s.y=Math.random()*h; } }
      initSymbols(); animate(); window.addEventListener('resize', handleResize);

      // ========== 导航切换逻辑 ==========
      const container = document.getElementById('pageContainer');
      const navLinks = document.querySelectorAll('.nav-links a');
      const slider = document.getElementById('navSlider');

      // 项目卡片数据
      const projectData = [
        { title: 'α项目Α 像素文本绘制', desc: '基于上划线实现像素文本绘制，适用于wechat，QQ', link: 'alpha.html' },
        { title: 'β项目Β', desc: '敬请期待', link: 'beta.html' },
        { title: 'γ项目Γ', desc: '敬请期待', link: 'gamma.html' },
        { title: 'δ项目Δ', desc: '敬请期待', link: 'delta.html' },
        { title: 'ε项目Ε', desc: '敬请期待', link: 'epsilon.html' },
        { title: 'ζ项目Ζ', desc: '敬请期待', link: 'zeta.html' },
        { title: 'η项目Η', desc: '敬请期待', link: 'eta.html' },
        { title: 'θ项目Θ', desc: '敬请期待', link: 'theta.html' },
        { title: 'ι项目Ι', desc: '敬请期待', link: 'Iota.html' },
        { title: 'κ项目Κ', desc: '敬请期待', link: 'Kappa.html' },
        { title: 'λ项目Λ', desc: '敬请期待', link: 'Lambda.html' },
        { title: 'μ项目Μ', desc: '敬请期待', link: 'Mu.html' },
        { title: 'ν项目Ν', desc: '敬请期待', link: 'Nu.html' },
        { title: 'ξ项目Ν', desc: '敬请期待', link: 'Xi.html' },
        { title: 'ο项目Ο', desc: '敬请期待', link: 'Omicron.html' }
        { title: '后续出现的项目', desc:'πρστυφχψω', link: '？.html' }
      ];

      const grid = document.getElementById('projectGrid');
      if (grid) {
        projectData.forEach((item) => {
          const card = document.createElement('div');
          card.className = 'project-card';
          const icon = document.createElement('div'); icon.className = 'placeholder-icon'; icon.textContent = '◈';
          card.appendChild(icon);
          const title = document.createElement('h3'); title.textContent = item.title; card.appendChild(title);
          const desc = document.createElement('p'); desc.className = 'desc'; desc.textContent = item.desc; card.appendChild(desc);
          
          const btn = document.createElement('button');
          btn.className = 'btn';
          btn.textContent = '查看 →';
          btn.setAttribute('data-href', item.link);
          btn.addEventListener('click', function(e) {
            const href = this.getAttribute('data-href');
            if (href) {
              window.location.href = href;
            } else {
              alert('项目链接未配置');
            }
          });
          card.appendChild(btn);
          grid.appendChild(card);
        });
      }

      // 更新导航横线位置
      function updateSlider(activeLink) {
        const parent = activeLink.parentElement;
        const rect = activeLink.getBoundingClientRect();
        const parentRect = parent.getBoundingClientRect();
        slider.style.left = (rect.left - parentRect.left) + 'px';
        slider.style.width = rect.width + 'px';
      }

      let currentPage = 'home';
      const homeLink = document.querySelector('[data-page="home"]');
      updateSlider(homeLink);

      function switchPage(page) {
        if (page === currentPage) return;
        navLinks.forEach(a => a.classList.remove('active'));

        const targetLink = document.querySelector(`[data-page="${page}"]`);
        if (targetLink) {
          targetLink.classList.add('active');
          updateSlider(targetLink);
        }

        if (page === 'home') {
          container.classList.remove('show-projects');
          container.classList.add('slide-right');
          currentPage = 'home';
        } else if (page === 'projects') {
          container.classList.remove('slide-right');
          container.classList.add('show-projects');
          currentPage = 'projects';
        }
      }

      navLinks.forEach(link => {
        link.addEventListener('click', function(e) {
          e.preventDefault();
          const page = this.dataset.page;
          if (page === 'home' || page === 'projects') {
            switchPage(page);
          }
        });
      });

      container.classList.remove('show-projects');
      container.classList.add('slide-right');

      window.addEventListener('resize', function() {
        const activeLink = document.querySelector('.nav-links a.active');
        if (activeLink) updateSlider(activeLink);
      });

    })();
  </script>
</body>
</html>
